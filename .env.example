# CamPost Pipeline 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 만들고 실제 값으로 채워주세요:
#   cp .env.example .env

# ── DB 연결 (docker-compose의 campost-db 서비스와 맞춰야 함) ──
POSTGRES_DB=campost
POSTGRES_USER=campost
POSTGRES_PASSWORD=campost1234

# ── 크롤러 설정 ──
CRAWL_INTERVAL_MINUTES=60   # 수집 주기 (분 단위, --loop 모드에서만 사용)
HEADLESS=true               # false 로 바꾸면 브라우저 창이 열림 (디버깅용)

# ── DB 호스트 (컨테이너 이름, 변경 불필요) ──
DB_HOST=db
DB_PORT=5432
