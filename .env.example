# CamPost Pipeline 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 만들고 실제 값으로 채워주세요:
#   cp .env.example .env

# ── DB 연결 (docker-compose의 campost-db 서비스와 맞춰야 함) ──
POSTGRES_DB=<REQUIRED_POSTGRES_DB>
POSTGRES_USER=<REQUIRED_POSTGRES_USER>
POSTGRES_PASSWORD=<REQUIRED_POSTGRES_PASSWORD>

# ── 크롤러 설정 ──
CRAWL_INTERVAL_MINUTES=60   # 수집 주기 (분 단위, --loop 모드에서만 사용)
HEADLESS=true               # false 로 바꾸면 브라우저 창이 열림 (디버깅용)

# ── 활성 소스 제한 (선택, 기본값: 전체 소스) ──
# 쉼표로 구분된 학과 코드를 지정하면 해당 학과만 크롤링한다.
# 미설정 시 모든 학과(SW, ACE, MOBILE, STAT, INDSEC, SWCU) 크롤링.
# 데모 권장: CRAWL_SOURCES=SW,ACE  (안정적으로 검증된 2개 학과)
# CRAWL_SOURCES=SW,ACE

# ── DB 호스트 (컨테이너 이름, 변경 불필요) ──
DB_HOST=db
DB_PORT=5432

# ── Gemini AI 설정 ──
# Google AI Studio에서 무료 발급: https://aistudio.google.com/apikey
# 미설정 시 regex만 사용 (AI 추출 비활성화)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
